# DATABASE_URL: Required for connecting to Neon PostgreSQL.
# Example: postgresql://user:password@endpoint.neon.tech/dbname?sslmode=require
DATABASE_URL=""

# JWT_SECRET: Required for authentication cookies
JWT_SECRET="super-secret-key-for-jwt"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
